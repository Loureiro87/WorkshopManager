@model IEnumerable<WorkshopManager.Domain.Entities.Pieza>

@{
    ViewData["Title"] = "Piezas";
}

<h2>📦 Gestión de Piezas</h2>

<div class="d-flex justify-content-between mb-3">
    <a asp-action="Create" class="btn btn-primary">
        Nueva pieza
    </a>
</div>

<table class="table table-striped table-hover"> 
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Referencia</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Estado</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @{
            foreach(var pieza in Model)
            {
                <tr>
                    <td>@pieza.Nombre</td>
                    <td>@pieza.Referencia</td>
                    <td>@pieza.Precio</td>
                    <td>@pieza.Stock</td>
                    <td>
                        @if(pieza.Activa)
                        {
                            <span class="badge bg-success">Activa</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactiva</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@pieza.Id" class="btn btn-sm btn-warning">Editar</a>
                        @if(pieza.Activa)
                        {
                            <form asp-action="Deshabilitar" asp-route-id="@pieza.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Deshabilitar
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Activar" asp-route-id="@pieza.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Activar
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>